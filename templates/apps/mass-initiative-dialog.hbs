{{!-- Mass Initiative Dialog Template — Card Grid Dashboard --}}
<form class="mass-initiative-form">
    {{!-- Header --}}
    <div class="dialog-header">
        <h2 class="header-title"><i class="fas fa-users"></i> NPC Initiative — Runde {{round}}</h2>
        
        <div class="progress-row">
            <div class="progress-bar">
                <div class="progress-fill" style="width: {{progressPercent}}%;"></div>
            </div>
            <span class="progress-text">{{processedCount}} von {{totalCount}} NPCs fertig</span>
        </div>

        <div class="batch-controls">
            <select class="batch-action-select" name="batchAction">
                <option value="">— Aktion für alle wählen —</option>
                {{#each availableActions as |action|}}
                <option value="{{action.id}}">{{action.name}} (INI {{#if (gte action.iniMod 0)}}+{{/if}}{{action.iniMod}})</option>
                {{/each}}
            </select>
            <button type="button" class="batch-btn apply-batch-btn" data-action="applyBatch">
                <i class="fas fa-check-double"></i> Auf alle anwenden
            </button>
            <button type="button" class="batch-btn roll-all-dice-btn" data-action="rollAllDice">
                <i class="fas fa-dice"></i> Würfel alle
            </button>
        </div>

        <label class="filter-toggle">
            <input type="checkbox" name="filterUnprocessed" {{#if filterDefault}}checked{{/if}}/>
            Nur unbearbeitete
        </label>
    </div>

    {{!-- Card Grid --}}
    <div class="dialog-content">
        <div class="npc-card-grid">
            {{#each npcs as |npc|}}
            <div class="npc-card {{#if npc.state.movedAction}}is-locked{{/if}} {{#if npc.needsDiceSelection}}needs-selection{{/if}} {{#if npc.isFiltered}}is-filtered{{/if}}" data-combatant-id="{{npc.combatantId}}">
                
                {{!-- Card Header --}}
                <div class="card-header">
                    <img src="{{npc.img}}" alt="" class="card-portrait"/>
                    <span class="card-name">{{npc.name}}</span>
                    <div class="card-base-ini">INI {{npc.baseIni}}</div>
                    {{#if npc.state.hasRolled}}
                        {{#if npc.needsDiceSelection}}
                        <span class="status-badge warning" title="Bitte Würfel auswählen"><i class="fas fa-exclamation-triangle"></i></span>
                        {{else}}
                        <span class="status-badge rolled" title="Fertig"><i class="fas fa-check"></i></span>
                        {{/if}}
                    {{/if}}
                    {{#if npc.state.movedAction}}
                    <span class="status-badge locked" title="Verzögert"><i class="fas fa-lock"></i></span>
                    {{/if}}
                </div>

                {{!-- Locked Subtitle --}}
                {{#if npc.state.movedAction}}
                <div class="locked-subtitle">⏱️ Verzögert — {{npc.state.movedActionRounds}}. Runde</div>
                {{/if}}

                {{!-- Action Chips --}}
                <div class="card-actions">
                    {{#each npc.actionChips as |chip|}}
                    <div class="action-chip {{#if chip.isLocked}}locked{{else}}selected{{/if}}" data-action-id="{{chip.id}}">
                        <img src="{{chip.img}}" alt="" width="18" height="18" style="border-radius:2px;"/>
                        <span>{{chip.name}}</span>
                        <span class="chip-ini-cost {{#if (lt chip.iniMod 0)}}negative{{/if}}">INI {{#if (gte chip.iniMod 0)}}+{{/if}}{{chip.iniMod}}</span>
                        {{#unless chip.isLocked}}
                        <span class="chip-remove" title="Entfernen"><i class="fas fa-times"></i></span>
                        {{/unless}}
                    </div>
                    {{/each}}
                    
                    {{#unless npc.state.movedAction}}
                    <div class="multi-select-container {{#if (gte npc.actionChips.length 2)}}is-disabled{{/if}}">
                        <multi-select name="actions-{{npc.combatantId}}" {{#if (gte npc.actionChips.length 2)}}disabled{{/if}}>
                            {{{selectOptions ../availableActions selected=npc.state.selectedActionIds valueAttr="id" labelAttr="name"}}}
                        </multi-select>
                    </div>
                    {{/unless}}
                </div>

                {{!-- Modifier Row --}}
                <div class="card-modifiers">
                    <div class="form-group">
                        <label>INI-Mod</label>
                        <input type="number" class="ini-input" name="iniMod-{{npc.combatantId}}" value="{{npc.state.iniMod}}" {{#if npc.isNegativeIni}}disabled{{/if}}/>
                    </div>
                    <div class="form-group at-input">
                        <label>AT-Mod</label>
                        <input type="number" name="atMod-{{npc.combatantId}}" value="{{npc.state.atMod}}" {{#if npc.state.movedAction}}disabled{{/if}}/>
                    </div>
                    <div class="form-group vt-input">
                        <label>VT-Mod</label>
                        <input type="number" name="vtMod-{{npc.combatantId}}" value="{{npc.state.vtMod}}" {{#if npc.state.movedAction}}disabled{{/if}}/>
                    </div>
                </div>

                {{!-- Dice Section --}}
                <div class="card-dice">
                    <select class="dice-count-select" name="diceCount-{{npc.combatantId}}">
                        <option value="1" {{#if (eq npc.state.diceCount 1)}}selected{{/if}}>1 Würfel</option>
                        <option value="2" {{#if (eq npc.state.diceCount 2)}}selected{{/if}}>2 Würfel</option>
                    </select>
                    <button type="button" class="roll-dice-btn" data-combatant-id="{{npc.combatantId}}">
                        <i class="fas fa-dice-d6"></i> Würfeln
                    </button>
                    
                    {{#if npc.state.hasRolled}}
                    <div class="dice-results">
                        {{#each npc.diceData as |die|}}
                        <div class="dice-result {{#if die.selected}}selected{{/if}}" 
                             data-index="{{die.index}}">
                            <span class="dice-value">{{die.value}}</span>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="dice-results dice-placeholder">
                        <div class="dice-result">
                            <span class="dice-value">?</span>
                        </div>
                        {{#if (eq npc.state.diceCount 2)}}
                        <div class="dice-result">
                            <span class="dice-value">?</span>
                        </div>
                        {{/if}}
                    </div>
                    {{/if}}
                </div>

                {{!-- Result --}}
                <div class="card-result">
                    <span class="result-value {{#if npc.state.hasRolled}}{{#if (lt npc.totalIni 0)}}negative{{else}}positive{{/if}}{{else}}unknown{{/if}}">
                        {{#if npc.state.hasRolled}}{{npc.totalIni}}{{else}}?{{/if}}
                    </span>
                    <span class="result-info" title="Formel anzeigen" data-combatant-id="{{npc.combatantId}}">🛈</span>
                </div>
            </div>
            {{/each}}
        </div>
    </div>

    {{!-- Footer --}}
    <footer class="dialog-footer">
        <div class="dialog-buttons">
            <button type="button" class="cancel-btn" data-action="cancelIni">
                <i class="fas fa-times"></i> Abbrechen
            </button>
            <button type="button" class="ini-ansagen-btn" data-action="iniAnsagen">
                <i class="fas fa-bullhorn"></i> INI ansagen (alle)
            </button>
        </div>
    </footer>
</form>
