<form class="ai-creature-dialog">
    {{#unless hasApiKey}}
    <div class="ai-warning">
        <i class="fas fa-exclamation-triangle"></i>
        <strong>Kein API-Key konfiguriert.</strong>
        <p>Bitte konfiguriere einen DeepSeek API-Key in den <a class="ai-open-settings" href="#">Moduleinstellungen</a>.</p>
    </div>
    {{/unless}}

    <div class="form-group">
        <label>Stärke</label>
        <select name="strength">
            {{#each strengthOptions}}
            <option value="{{value}}" {{#if (eq value ../strength)}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
        <p class="hint">Bestimmt die Attributswerte und Kampfkraft der generierten Kreaturen.</p>
    </div>

    <div class="form-group">
        <label>Anzahl</label>
        <input type="number" name="count" value="{{count}}" min="1" max="10" />
        <p class="hint">Anzahl der zu generierenden Kreaturen (1-10).</p>
    </div>

    <div class="form-group">
        <label>Typ</label>
        <select name="type">
            {{#each typeOptions}}
            <option value="{{value}}" {{#if (eq value ../type)}}selected{{/if}}>{{label}}</option>
            {{/each}}
        </select>
        <p class="hint">Kreaturentyp. "Beliebig" lässt die KI frei wählen.</p>
    </div>

    <div class="form-group">
        <label>Beschreibung</label>
        <textarea name="description" rows="4" placeholder="z.B. Goblin-Krieger mit Kurzschwertern, zwei mit Bögen">{{description}}</textarea>
        <p class="hint">Beschreibe, welche Art von Kreaturen du möchtest — Bewaffnung, Fähigkeiten, Thema.</p>
    </div>

    {{#if error}}
    <div class="ai-error">
        <i class="fas fa-times-circle"></i> {{error}}
    </div>
    {{/if}}

    <div class="form-actions">
        <button type="submit" class="ai-generate-btn" data-action="generate" {{#if isLoading}}disabled{{/if}} {{#unless hasApiKey}}disabled{{/unless}}>
            {{#if isLoading}}
            <i class="fas fa-spinner fa-spin"></i> Generiere...
            {{else}}
            <i class="fas fa-robot"></i> Generieren
            {{/if}}
        </button>
    </div>
</form>
