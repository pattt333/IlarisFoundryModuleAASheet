{{!-- Initiative Dialog Dashboard Template --}}
<form class="initiative-dialog-form {{#if isLocked}}locked-state{{/if}}">
    {{!-- Header --}}
    <div class="dialog-header">
        <div class="actor-info">
            <img src="{{actor.img}}" alt="{{actor.name}}" class="actor-portrait"/>
            <div class="actor-details">
                <h2>{{actor.name}} <span class="round-badge">Runde {{round}}</span></h2>
                <div class="base-stats">
                    <span class="base-ini">Basis-INI: <strong>{{baseIni}}</strong></span>
                    {{#if isLocked}}
                    <span class="locked-badge"><i class="fas fa-lock"></i> Verzögert ({{movedActionRounds}} Rd.)</span>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>

    <div class="dialog-content">
        <div class="dashboard-grid">
            {{!-- Left Column: Actions & Modifiers --}}
            <div class="dashboard-left">
                {{#if isLocked}}
                {{!-- LOCKED State: Show locked action card, gray out others --}}
                <section class="actions-section locked">
                    <h3><i class="fas fa-lock"></i> Aktion gesperrt</h3>
                    <div class="action-cards">
                        {{#if lockedAction}}
                        <div class="action-card locked-card">
                            <img src="{{lockedAction.img}}" alt="{{lockedAction.name}}" class="action-card-img"/>
                            <div class="action-card-info">
                                <strong>{{lockedAction.name}}</strong>
                                {{#if lockedWeapon}}
                                <span class="locked-weapon"><i class="fas fa-sword"></i> {{lockedWeapon.name}}</span>
                                {{/if}}
                                <span class="action-ini-cost">INI {{lockedAction.iniMod}} <em>(bezahlt)</em></span>
                                <span class="delay-text"><i class="fas fa-clock"></i> verzögert um {{movedActionRounds}} Runde{{#if (gt movedActionRounds 1)}}n{{/if}}</span>
                            </div>
                            <div class="lock-icon"><i class="fas fa-lock"></i></div>
                        </div>
                        {{/if}}
                        {{#each availableActions as |action|}}
                        {{#unless (eq action.id ../lockedActionId)}}
                        <div class="action-card disabled-card">
                            <img src="{{action.img}}" alt="{{action.name}}" class="action-card-img"/>
                            <div class="action-card-info">
                                <strong>{{action.name}}</strong>
                                <span class="action-ini-cost">INI {{action.iniMod}}</span>
                            </div>
                        </div>
                        {{/unless}}
                        {{/each}}
                    </div>
                </section>
                {{else}}
                {{!-- FRESH State: Clickable action cards --}}
                <section class="actions-section">
                    <h3><i class="fas fa-running"></i> Aktionen <span class="hint">(max. 2, niedrigster INI-Mod zählt)</span></h3>
                    <div class="action-cards">
                        {{#each availableActions as |action|}}
                        <div class="action-card {{#if (includes ../selectedActionIds action.id)}}selected{{/if}}"
                             data-action-id="{{action.id}}"
                             title="{{action.description}}">
                            <img src="{{action.img}}" alt="{{action.name}}" class="action-card-img"/>
                            <div class="action-card-info">
                                <strong>{{action.name}}</strong>
                                <span class="action-ini-cost {{#if (lt action.iniMod 0)}}negative{{/if}}">INI {{#if (gte action.iniMod 0)}}+{{/if}}{{action.iniMod}}</span>
                            </div>
                            <div class="action-card-check">{{#if (includes ../selectedActionIds action.id)}}<i class="fas fa-check-circle"></i>{{/if}}</div>
                        </div>
                        {{/each}}
                    </div>

                    {{!-- Weapon & Combined Action (FRESH only) --}}
                    <div class="weapon-row">
                        <div class="form-group weapon-select-group">
                            <label for="selectedWeapon"><i class="fas fa-sword"></i> Waffe</label>
                            <select name="selectedWeapon" id="selectedWeapon" {{#unless availableWeapons.length}}disabled{{/unless}}>
                                <option value="">keine Waffe</option>
                                {{{selectOptions availableWeapons selected=selectedWeaponId valueAttr="id" labelAttr="name"}}}
                            </select>
                        </div>
                        <div class="form-group checkbox-group">
                            <label class="checkbox-label" title="Bei kombinierten Aktionen sind AT und VT um 4 erschwert">
                                <input type="checkbox" name="kombinierteAktion" {{#if kombinierteAktion}}checked{{/if}}/>
                                <span>Kombiniert (-4 AT/VT)</span>
                            </label>
                        </div>
                    </div>

                    {{#if selectedWeaponData}}
                    <div class="weapon-properties">
                        <strong>Eigenschaften:</strong> {{eigenschaften selectedWeaponData.system.eigenschaften ", "}}
                    </div>
                    {{/if}}
                </section>
                {{/if}}

                {{!-- Modifier Section (always visible, INI mod always enabled) --}}
                <section class="modifier-section">
                    <h3><i class="fas fa-sliders-h"></i> Modifikatoren</h3>
                    <div class="modifier-row">
                        <div class="form-group">
                            <label for="iniMod">INI-Mod</label>
                            <input type="number" name="iniMod" id="iniMod" value="{{iniMod}}"/>
                        </div>
                        <div class="form-group">
                            <label for="atMod">AT-Mod</label>
                            <input type="number" name="atMod" id="atMod" value="{{atMod}}" {{#if isLocked}}disabled{{/if}}/>
                        </div>
                        <div class="form-group">
                            <label for="vtMod">VT-Mod</label>
                            <input type="number" name="vtMod" id="vtMod" value="{{vtMod}}" {{#if isLocked}}disabled{{/if}}/>
                        </div>
                    </div>
                </section>
            </div>

            {{!-- Right Column: Dice --}}
            <div class="dashboard-right">
                <section class="dice-section">
                    <h3><i class="fas fa-dice"></i> Würfeln</h3>

                    {{#unless manualRolling}}
                    <div class="form-group dice-count-group">
                        <select name="diceCount" id="diceCount" title="Man kann irgendein Ergebnis von den beiden wählen">
                            <option value="1" {{#if (eq diceCount 1)}}selected{{/if}}>1 Würfel</option>
                            <option value="2" {{#if (eq diceCount 2)}}selected{{/if}}>2 Würfel (Auswahl)</option>
                        </select>
                    </div>
                    {{/unless}}

                    <button type="button" class="roll-dice-btn">
                        <i class="fas fa-dice-d6"></i> {{#if hasRolled}}Neu würfeln{{else}}Würfeln{{/if}}
                    </button>

                    {{#if hasRolled}}
                    <div class="dice-results">
                        {{#each diceResults as |result index|}}
                        <div class="dice-result {{#if (eq ../selectedDiceIndex index)}}selected{{/if}}"
                             data-index="{{index}}"
                             title="{{#if (eq ../diceCount 2)}}Klicken zum Auswählen{{/if}}">
                            <div class="dice-face d6 show-{{result}}">
                                <span class="dice-value">{{result}}</span>
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="dice-results dice-placeholder">
                        <div class="dice-result" data-index="0">
                            <div class="dice-face d6 show-unknown">
                                <span class="dice-value">?</span>
                            </div>
                        </div>
                        {{#if (eq diceCount 2)}}
                        <div class="dice-result" data-index="1">
                            <div class="dice-face d6 show-unknown">
                                <span class="dice-value">?</span>
                            </div>
                        </div>
                        {{/if}}
                    </div>
                    {{/if}}
                </section>
            </div>
        </div>

        {{!-- Formula Breakdown --}}
        <section class="formula-breakdown">
            <div class="formula-parts">
                {{#each formulaParts as |part index|}}
                <span class="formula-part">
                    <span class="formula-label">{{part.label}}</span>
                    <span class="formula-value {{#if (lt (num part.value) 0)}}negative{{/if}}">{{part.value}}</span>
                </span>
                {{#unless @last}}
                <span class="formula-operator">+</span>
                {{/unless}}
                {{/each}}
            </div>
            <div class="formula-total">
                <span class="formula-equals">=</span>
                <span class="formula-result {{#if negativeIni}}negative{{else}}positive{{/if}}">
                    {{calculatedIni}}
                </span>
            </div>
        </section>
    </div>

    <footer class="dialog-footer">
        <div class="dialog-buttons">
            <button type="button" class="cancel-btn">
                <i class="fas fa-times"></i> Abbrechen
            </button>
            <button type="button" class="ini-ansagen-btn {{#unless hasRolled}}disabled{{/unless}}">
                <i class="fas fa-bullhorn"></i> INI ansagen
            </button>
        </div>
        {{#unless hasRolled}}
        <span class="warning-text"><i class="fas fa-exclamation-triangle"></i> Bitte erst würfeln!</span>
        {{/unless}}
    </footer>
</form>
