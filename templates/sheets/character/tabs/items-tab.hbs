{{!-- Items Tab --}}
<div class="tab items {{tab.cssClass}}" data-group="primary" data-tab="items">
    <div class="flexcol">
        {{!-- Money Management Section --}}
        <div class="items-section">
            <div class="items-header">
                <h3>Geld</h3>
            </div>
            <div class="geld-row">
                <div class="geld-field">
                    <label>Dukaten</label>
                    <input
                        name="system.geld.dukaten"
                        value="{{actor.system.geld.dukaten}}"
                        type="text"
                        data-dtype="Number"
                    />
                </div>
                <div class="geld-field">
                    <label>Silbertaler</label>
                    <input
                        name="system.geld.silbertaler"
                        value="{{actor.system.geld.silbertaler}}"
                        type="text"
                        data-dtype="Number"
                    />
                </div>
                <div class="geld-field">
                    <label>Heller</label>
                    <input
                        name="system.geld.heller"
                        value="{{actor.system.geld.heller}}"
                        type="text"
                        data-dtype="Number"
                    />
                </div>
                <div class="geld-field">
                    <label>Kreuzer</label>
                    <input
                        name="system.geld.kreuzer"
                        value="{{actor.system.geld.kreuzer}}"
                        type="text"
                        data-dtype="Number"
                    />
                </div>
                <button class="item-control" data-clicktype="shorten_money">
                    <i class="fas fa-calculator"></i> zusammenrechnen
                </button>
            </div>
        </div>

        {{!-- Equipment Section --}}
        <div class="items-section">
            <div class="items-header">
                <h3>Ausrüstung</h3>
                <div class="item-controls">
                    <a class="item-control item-create" data-action="itemCreate" title="Gegenstand erstellen" data-itemclass="gegenstand"><i class="fas fa-plus"></i> Gegenstand hinzufügen</a>
                </div>
            </div>
        </div>
        
        {{> "modules/ilaris-alternative-actor-sheet/templates/components/supporting.hbs"}}
        {{> "modules/ilaris-alternative-actor-sheet/templates/components/carrying.hbs"}}
        {{> "modules/ilaris-alternative-actor-sheet/templates/components/handcart.hbs"}}
    </div>
</div>
